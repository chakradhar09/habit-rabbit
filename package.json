{
  "name": "habit-rabbit",
  "version": "1.0.0",
  "description": "Habit tracking app with heatmap visualization",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "seed": "node backend/utils/seedData.js",
    "verify:sprint1": "node backend/utils/sprint1Verification.js",
    "verify:sprint2": "node backend/utils/sprint2Verification.js",
    "verify:all": "npm run verify:sprint1 && npm run verify:sprint2"
  },
  "keywords": [
    "habit",
    "tracker",
    "productivity"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.1.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  }
}
