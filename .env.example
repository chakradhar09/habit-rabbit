# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/habit-rabbit?retryWrites=true&w=majority

# JWT Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d
JWT_ISSUER=habit-rabbit
JWT_AUDIENCE=habit-rabbit-client

# Server Port
PORT=5000

# Frontend URL (for CORS)
# Use FRONTEND_URLS for a comma-separated allowlist in production
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000,http://localhost:5000

# Login hardening
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=10
LOGIN_ATTEMPT_WINDOW_MINUTES=30

# Optional AI configuration
GEMINI_API_KEY=your-gemini-api-key
